-- ============================================================
-- ЛОГИКА КЛОНИРОВАНИЯ
-- ============================================================

local function setSuccess(text)
	statusLabel.Text = text
	statusLabel.TextColor3 = Color3.fromRGB(80, 255, 140)
end

local function setError(text)
	statusLabel.Text = text
	statusLabel.TextColor3 = Color3.fromRGB(255, 90, 90)
end

local function setWorking(text)
	statusLabel.Text = text
	statusLabel.TextColor3 = Color3.fromRGB(200, 200, 100)
end

local function doClone()
	local toolName = nameInput.Text
	if toolName == "" then
		setError("Введите имя Tool!")
		return
	end

	setWorking("Клонирую '" .. toolName .. "'...")

	local success, message = giveClonedTool(toolName)
	if success then
		setSuccess(message)
	else
		setError(message)
	end
end

cloneButton.MouseButton1Click:Connect(doClone)

nameInput.FocusLost:Connect(function(enterPressed)
	if enterPressed then
		doClone()
	end
end)


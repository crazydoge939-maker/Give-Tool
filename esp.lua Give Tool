-- ========== Перетаскивание GUI ==========
local dragging = false
local dragInput
local dragStart
local startPos

titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

titleBar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - dragStart
		local viewport = workspace.CurrentCamera.ViewportSize
		local scaleX = delta.X / viewport.X
		local scaleY = delta.Y / viewport.Y
		mainFrame.Position = UDim2.new(
			startPos.X.Scale + scaleX,
			0,
			startPos.Y.Scale + scaleY,
			0
		)
	end
end)

-- ========== Функция создания Tool (после GUI) ==========
local function createTool(toolName)
	if currentTool then
		currentTool.Parent = nil
		currentTool = nil
	end

	local char = player.Character
	if not char then return end
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	local tool = Instance.new("Tool")
	tool.Name = (toolName ~= "" and toolName) or "Tool"
	tool.RequiresHandle = true

	local handle = Instance.new("Part")
	handle.Name = "Handle"
	handle.Size = Vector3.new(1, 1, 2)
	handle.Color = Color3.fromRGB(255, 120, 50)
	handle.Material = Enum.Material.SmoothPlastic
	handle.Anchored = false
	handle.CanCollide = false
	handle.Massless = true
	handle.Parent = tool

	local mesh = Instance.new("SpecialMesh")
	mesh.MeshType = Enum.MeshType.Brick
	mesh.Scale = Vector3.new(0.8, 0.8, 1.5)
	mesh.Parent = handle

	usedValue = Instance.new("BoolValue")
	usedValue.Name = "Used"
	usedValue.Value = false
	usedValue.Parent = tool

	tool.Parent = char
	currentTool = tool

	statusLabel.Text = "Tool: " .. tool.Name .. " | Used: No"
	statusLabel.TextColor3 = Color3.fromRGB(180, 180, 200)
	useButton.BackgroundColor3 = Color3.fromRGB(0, 150, 80)
	useButton.Text = "Use Tool"

	tool.Activated:Connect(function()
		if usedValue then
			usedValue.Value = true
		end
		statusLabel.Text = "Tool: " .. tool.Name .. " | Used: Yes"
		statusLabel.TextColor3 = Color3.fromRGB(0, 255, 120)
		useButton.BackgroundColor3 = Color3.fromRGB(160, 50, 50)
		useButton.Text = "Used!"
	end)
end

-- ========== Логика кнопки ==========
useButton.MouseButton1Click:Connect(function()
	if currentTool then
		-- Tool уже создан — помечаем как Used
		if usedValue then
			usedValue.Value = true
		end
		statusLabel.Text = "Tool: " .. currentTool.Name .. " | Used: Yes"
		statusLabel.TextColor3 = Color3.fromRGB(0, 255, 120)
		useButton.BackgroundColor3 = Color3.fromRGB(160, 50, 50)
		useButton.Text = "Used!"
	else
		-- Создаём Tool с именем из поля ввода
		local toolName = nameInput.Text
		createTool(toolName)
		useButton.BackgroundColor3 = Color3.fromRGB(0, 150, 80)
		useButton.Text = "Use Tool"
	end
end)

-- Enter в поле ввода тоже создаёт Tool
nameInput.FocusLost:Connect(function(enterPressed)
	if enterPressed and not currentTool then
		createTool(nameInput.Text)
		useButton.BackgroundColor3 = Color3.fromRGB(0, 150, 80)
		useButton.Text = "Use Tool"
	end
end)

-- ========== Респаун персонажа ==========
player.CharacterAdded:Connect(function(newChar)
	character = newChar
	newChar:WaitForChild("Humanoid")

	-- Сброс состояния
	currentTool = nil
	usedValue = nil
	statusLabel.Text = "No tool created"
	statusLabel.TextColor3 = Color3.fromRGB(180, 180, 200)
	useButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
	useButton.Text = "Create Tool"
	nameInput.Text = ""
end)

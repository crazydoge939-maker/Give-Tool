-- ============================================================
-- ГЛУБОКОЕ КЛОНИРОВАНИЕ TOOL
-- Копирует: все дочерние объекты, атрибуты, теги, свойства
-- ============================================================

local function copyAttributesAndTags(source, dest)
	-- Копируем все атрибуты
	for name, value in source:GetAttributes() do
		dest:SetAttribute(name, value)
	end
	-- Копируем все теги
	for _, tag in source:GetTags() do
		dest:AddTag(tag)
	end
end

local function deepCloneTool(original)
	if not original or not original:IsA("Tool") then
		return nil
	end

	-- Instance:Clone() копирует все дочерние объекты и свойства,
	-- но НЕ копирует атрибуты и теги — их переносим вручную
	local clone = original:Clone()

	-- Копируем атрибуты и теги на корневой Tool
	copyAttributesAndTags(original, clone)

	-- Копируем атрибуты и теги на всех потомков
	-- Идём по пути от оригинала к клону, чтобы найти пары
	for _, srcDesc in original:GetDescendants() do
		-- Строим путь от оригинала до потомка
		local path = {}
		local current = srcDesc
		while current and current ~= original do
			table.insert(path, 1, current.Name)
			current = current.Parent
		end

		-- Ищем того же потомка в клоне
		local dstDesc = clone
		for _, segment in path do
			dstDesc = dstDesc:FindFirstChild(segment)
			if not dstDesc then break end
		end

		if dstDesc then
			copyAttributesAndTags(srcDesc, dstDesc)
		end
	end

	return clone
end

-- ============================================================
-- ПОИСК TOOL ПО ИМЕНИ
-- Ищет в: StarterPack, Backpack, Character, Workspace
-- ============================================================

local function findToolByName(toolName)
	if not toolName or toolName == "" then return nil end

	local searchLocations = {
		StarterPack,
		player:FindFirstChild("Backpack"),
		player.Character,
		workspace,
	}

	local toolNameLower = string.lower(toolName)

	for _, location in searchLocations do
		if location then
			for _, descendant in location:GetDescendants() do
				if descendant:IsA("Tool") and string.lower(descendant.Name) == toolNameLower then
					return descendant
				end
			end
		end
	end

	return nil
end

-- ============================================================
-- ВЫДАЧА КЛОНА TOOL ИГРОКУ
-- ============================================================

local function giveClonedTool(toolName)
	local original = findToolByName(toolName)
	if not original then
		return false, "Tool '" .. toolName .. "' не найден"
	end

	local clone = deepCloneTool(original)
	if not clone then
		return false, "Не удалось клонировать Tool"
	end

	-- Выдаём в Backpack (если персонаж жив) или в Character
	local character = player.Character
	local backpack = player:FindFirstChild("Backpack")

	if backpack then
		clone.Parent = backpack
	elseif character then
		clone.Parent = character
	else
		return false, "Нет Backpack или Character"
	end

	return true, "Tool '" .. clone.Name .. "' успешно клонирован и выдан!"
end

